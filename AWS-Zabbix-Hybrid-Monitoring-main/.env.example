# ============================================================
# Zabbix Docker Stack — Environment Variables
# ============================================================
# Copy this file to .env before running docker compose up:
#   cp .env.example .env
#
# ⚠️  IMPORTANT: Change all passwords before deploying!
# ============================================================

# --- MySQL ---
MYSQL_DATABASE=zabbix
MYSQL_USER=zabbix
MYSQL_PASSWORD=zabbix_pwd          # ← CHANGE THIS
MYSQL_ROOT_PASSWORD=root_pwd       # ← CHANGE THIS

# --- Zabbix Web ---
PHP_TZ=Africa/Casablanca           # Set your timezone (e.g. Europe/Paris, America/New_York)
# Full list: https://www.php.net/manual/en/timezones.php
